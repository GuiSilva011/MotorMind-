generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  Nome      String
  Email     String   @unique
  Senha     String
  Role      Role
  CreatedAt DateTime @default(now())
}

model Cliente {
  id              Int      @id @default(autoincrement())
  nome            String
  cpf             String   @db.VarChar(11)

  email           String?
  dataNascimento  DateTime?
  rg              String?
  cep             String?
  endereco        String?
  bairro          String?
  cidade          String?
  uf              String?  @db.VarChar(2)
  numero          String?
  celular         String?

  createdAt       DateTime @default(now())
  veiculos        Veiculo[]
}

model Veiculo {
  id         Int      @id @default(autoincrement())
  placa      String   @db.VarChar(7)
  chassi     String?  @unique @db.VarChar(17)
  marca      String?
  modelo     String?
  ano        Int?
  anoModelo  Int?
  createdAt  DateTime @default(now())

  clienteId  Int
  cliente    Cliente  @relation(fields: [clienteId], references: [id])
}

enum Role {
  ADMIN
  OPERADOR
  TECNICO
}